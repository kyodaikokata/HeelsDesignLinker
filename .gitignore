## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# Visual Studio Code
.vscode/

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Local dual-build output
dist/

# Build outputs that should be included (release git repo tracks zips)
!plugins/HeelsDesignLinker/latest-cn.zip
!plugins/HeelsDesignLinker/latest-global.zip

# Dalamud
Dalamud/
*.json.old

# OS files
Thumbs.db
.DS_Store
